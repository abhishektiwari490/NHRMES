<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.nhrmes">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.NHRMES">
        <activity
            android:name=".MyAppointmentsActivity"
            android:exported="false" />
        <activity
            android:name=".AppointmentActivity"
            android:exported="false" />
        <activity
            android:name=".GovernmentDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".MyRequestAdapter"
            android:exported="false" />
        <activity
            android:name=".MyRequestsActivity"
            android:exported="false" />
        <activity
            android:name=".AdminDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".EmergencyRequestActivity"
            android:exported="false" /> <!-- ONLY ONE LAUNCHER ACTIVITY -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Other Activities -->
        <activity android:name=".MainActivity" />
        <activity android:name=".RegisterActivity" />
        <activity android:name=".ForgetPassword" />
        <activity android:name=".PatientDashboardActivity" />
        <activity android:name=".HospitalListActivity" />
    </application>

</manifest>