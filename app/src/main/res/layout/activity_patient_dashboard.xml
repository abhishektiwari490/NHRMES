<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Welcome Section -->
        <TextView
            android:id="@+id/txtWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome, Patient"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-time Healthcare Resource Monitoring"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="20dp"/>

        <!-- Stats Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Total Hospitals Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:background="#4CAF50"
                android:padding="15dp"
                android:orientation="vertical"
                android:layout_margin="5dp">

                <TextView
                    android:id="@+id/txtTotalHospitals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Hospitals"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- ICU Beds Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:background="#2196F3"
                android:padding="15dp"
                android:orientation="vertical"
                android:layout_margin="5dp">

                <TextView
                    android:id="@+id/txtAvailableICU"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available ICU Beds"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons -->
        <Button
            android:id="@+id/btnViewHospitals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Hospitals"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/btnRequestEmergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Request Emergency"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnMyRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Requests"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnBookAppointment"
            android:text="Book Doctor Appointment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnSOS"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚨 Emergency SOS"
            android:background="#D32F2F"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>